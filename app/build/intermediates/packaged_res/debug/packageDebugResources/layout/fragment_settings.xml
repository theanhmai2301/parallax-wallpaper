<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/settingsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="@dimen/screen_margin"
        android:layout_marginTop="@dimen/space_md"
        android:background="@drawable/bg_circle_glass"
        android:contentDescription="@string/cd_back"
        android:padding="10dp"
        android:src="@drawable/ic_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="?attr/colorOnBackground" />

    <TextView
        android:id="@+id/settingsHeaderTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_md"
        android:text="@string/settings_title"
        android:textAppearance="@style/TextAppearance.ParallaxWallpaper.Title"
        app:layout_constraintBottom_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toEndOf="@id/btnBack"
        app:layout_constraintTop_toTopOf="@id/btnBack" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/settingsScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/space_sm"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnBack">

    <LinearLayout
        android:id="@+id/settingsContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/screen_margin"
        android:paddingBottom="110dp">

        <!-- Appearance -->
        <TextView style="@style/TextAppearance.ParallaxWallpaper.Body"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xl" android:layout_marginBottom="@dimen/space_sm"
            android:text="@string/settings_appearance" android:textAllCaps="true"
            android:textColor="@color/brand_purple_light" android:textStyle="bold" android:textSize="12sp"
            android:letterSpacing="0.08" />

        <LinearLayout style="@style/SettingRow">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/settings_dark_mode" android:textAppearance="@style/TextAppearance.ParallaxWallpaper.Title" android:textSize="16sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/settings_dark_mode_sub" android:textAppearance="@style/TextAppearance.ParallaxWallpaper.Body" android:textSize="13sp" />
            </LinearLayout>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchDarkMode"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout style="@style/SettingRow">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/settings_dynamic_color" android:textAppearance="@style/TextAppearance.ParallaxWallpaper.Title" android:textSize="16sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/settings_dynamic_color_sub" android:textAppearance="@style/TextAppearance.ParallaxWallpaper.Body" android:textSize="13sp" />
            </LinearLayout>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchDynamic"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Parallax -->
        <TextView style="@style/TextAppearance.ParallaxWallpaper.Body"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xl" android:layout_marginBottom="@dimen/space_sm"
            android:text="@string/settings_parallax" android:textAllCaps="true"
            android:textColor="@color/brand_purple_light" android:textStyle="bold" android:textSize="12sp"
            android:letterSpacing="0.08" />

        <LinearLayout style="@style/SettingRow">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/settings_enable_parallax" android:textAppearance="@style/TextAppearance.ParallaxWallpaper.Title" android:textSize="16sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/settings_enable_parallax_sub" android:textAppearance="@style/TextAppearance.ParallaxWallpaper.Body" android:textSize="13sp" />
            </LinearLayout>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchParallax"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout style="@style/SettingRow" android:orientation="vertical" android:gravity="start">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/settings_sensitivity" android:textAppearance="@style/TextAppearance.ParallaxWallpaper.Title" android:textSize="16sp" />
            <com.google.android.material.slider.Slider
                android:id="@+id/sliderSensitivity"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xs"
                android:valueFrom="0.0" android:valueTo="1.0" android:value="0.5"
                app:thumbColor="@color/brand_purple"
                app:trackColorActive="@color/brand_purple"
                app:trackColorInactive="@color/surface_variant" />
        </LinearLayout>

        <!-- General -->
        <TextView style="@style/TextAppearance.ParallaxWallpaper.Body"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xl" android:layout_marginBottom="@dimen/space_sm"
            android:text="@string/settings_general" android:textAllCaps="true"
            android:textColor="@color/brand_purple_light" android:textStyle="bold" android:textSize="12sp"
            android:letterSpacing="0.08" />

        <LinearLayout android:id="@+id/rowClearCache" style="@style/SettingRow.Clickable">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/settings_clear_cache" android:textAppearance="@style/TextAppearance.ParallaxWallpaper.Title" android:textSize="16sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/settings_clear_cache_sub" android:textAppearance="@style/TextAppearance.ParallaxWallpaper.Body" android:textSize="13sp" />
            </LinearLayout>
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_refresh" android:importantForAccessibility="no"
                app:tint="@color/on_surface_variant" />
        </LinearLayout>

        <LinearLayout android:id="@+id/rowRate" style="@style/SettingRow.Clickable">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="@string/settings_rate" android:textAppearance="@style/TextAppearance.ParallaxWallpaper.Title" android:textSize="16sp" />
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_star" android:importantForAccessibility="no"
                app:tint="@color/on_surface_variant" />
        </LinearLayout>

        <LinearLayout android:id="@+id/rowPrivacy" style="@style/SettingRow.Clickable">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="@string/settings_privacy" android:textAppearance="@style/TextAppearance.ParallaxWallpaper.Title" android:textSize="16sp" />
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_chevron_right" android:importantForAccessibility="no"
                app:tint="@color/on_surface_variant" />
        </LinearLayout>

        <LinearLayout style="@style/SettingRow">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="@string/settings_version" android:textAppearance="@style/TextAppearance.ParallaxWallpaper.Title" android:textSize="16sp" />
            <TextView android:id="@+id/textVersion" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.ParallaxWallpaper.Body" />
        </LinearLayout>

    </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
