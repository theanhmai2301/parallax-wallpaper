<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_main"
    app:startDestination="@id/homeFragment">

    <!-- Global tab actions usable from any bottom-nav screen; pop back to home so the stack stays
         tab-like (home + at most one sub-screen). -->
    <action
        android:id="@+id/action_global_favorite"
        app:destination="@id/favoriteFragment"
        app:popUpTo="@id/homeFragment"
        app:enterAnim="@anim/fade_in"
        app:exitAnim="@anim/fade_in" />
    <action
        android:id="@+id/action_global_settings"
        app:destination="@id/settingsFragment"
        app:popUpTo="@id/homeFragment"
        app:enterAnim="@anim/fade_in"
        app:exitAnim="@anim/fade_in" />
    <action
        android:id="@+id/action_global_edit"
        app:destination="@id/editFragment"
        app:popUpTo="@id/homeFragment"
        app:enterAnim="@anim/fade_in"
        app:exitAnim="@anim/fade_in" />

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.galaxywall.app.ui.home.HomeFragment"
        android:label="@string/home_title"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_home_to_preview"
            app:destination="@id/previewFragment"
            app:enterAnim="@anim/fade_in" app:exitAnim="@anim/fade_in"
            app:popEnterAnim="@anim/fade_in" app:popExitAnim="@anim/fade_in" />
        <action
            android:id="@+id/action_home_to_edit"
            app:destination="@id/editFragment"
            app:enterAnim="@anim/fade_in" app:exitAnim="@anim/fade_in" />
        <action
            android:id="@+id/action_home_to_favorite"
            app:destination="@id/favoriteFragment" />
        <action
            android:id="@+id/action_home_to_settings"
            app:destination="@id/settingsFragment" />
    </fragment>

    <fragment
        android:id="@+id/previewFragment"
        android:name="com.galaxywall.app.ui.builder.PreviewFragment"
        android:label="Preview"
        tools:layout="@layout/fragment_preview">
        <action
            android:id="@+id/action_preview_to_edit"
            app:destination="@id/editFragment"
            app:enterAnim="@anim/fade_in" app:exitAnim="@anim/fade_in" />
        <action
            android:id="@+id/action_preview_to_result"
            app:destination="@id/resultFragment"
            app:enterAnim="@anim/fade_in" app:exitAnim="@anim/fade_in" />
    </fragment>

    <fragment
        android:id="@+id/editFragment"
        android:name="com.galaxywall.app.ui.builder.EditFragment"
        android:label="Edit"
        tools:layout="@layout/fragment_edit">
        <action
            android:id="@+id/action_edit_to_result"
            app:destination="@id/resultFragment"
            app:enterAnim="@anim/fade_in" app:exitAnim="@anim/fade_in" />
    </fragment>

    <fragment
        android:id="@+id/resultFragment"
        android:name="com.galaxywall.app.ui.builder.ResultFragment"
        android:label="Result"
        tools:layout="@layout/fragment_result">
        <!-- After a successful apply, show the success screen on top of Home (the builder stack
             above Home is popped) so the only way out is back to Home. -->
        <action
            android:id="@+id/action_result_to_success"
            app:destination="@id/successFragment"
            app:popUpTo="@id/homeFragment"
            app:popUpToInclusive="false"
            app:enterAnim="@anim/fade_in"
            app:exitAnim="@anim/fade_in" />
    </fragment>

    <fragment
        android:id="@+id/successFragment"
        android:name="com.galaxywall.app.ui.builder.SuccessFragment"
        android:label="Success"
        tools:layout="@layout/fragment_success" />

    <fragment
        android:id="@+id/favoriteFragment"
        android:name="com.galaxywall.app.ui.favorite.FavoriteFragment"
        android:label="@string/tab_favorites"
        tools:layout="@layout/fragment_favorite">
        <action
            android:id="@+id/action_favorite_to_preview"
            app:destination="@id/previewFragment"
            app:enterAnim="@anim/fade_in" app:exitAnim="@anim/fade_in" />
    </fragment>

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.galaxywall.app.ui.settings.SettingsFragment"
        android:label="@string/settings_title"
        tools:layout="@layout/fragment_settings" />

</navigation>
