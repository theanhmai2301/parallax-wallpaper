<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="62dp"
    app:cardBackgroundColor="@color/nav_bg"
    app:cardCornerRadius="26dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/glass_stroke"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/navHomeIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_home"
                app:tint="@color/brand_purple" />

            <TextView
                android:id="@+id/navHomeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="@string/nav_home"
                android:textColor="@color/brand_purple"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navCategory"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/navCategoryIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_folder"
                app:tint="@color/on_surface_variant" />

            <TextView
                android:id="@+id/navCategoryText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="@string/nav_category"
                android:textColor="@color/on_surface_variant"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navFavorite"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/navFavoriteIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_favorite"
                app:tint="@color/on_surface_variant" />

            <TextView
                android:id="@+id/navFavoriteText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="@string/nav_favorite"
                android:textColor="@color/on_surface_variant"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navSetting"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/navSettingIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_settings"
                app:tint="@color/on_surface_variant" />

            <TextView
                android:id="@+id/navSettingText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="@string/nav_setting"
                android:textColor="@color/on_surface_variant"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
