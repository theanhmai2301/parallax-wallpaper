<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_activated="true">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="#2E1B47" />
            <stroke android:width="2dp" android:color="@color/brand_purple" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="#241338" />
            <stroke android:width="1dp" android:color="#3A2C4D" />
        </shape>
    </item>
</selector>
